# Copy to supabase/.env.local for local edge-function dev:
#   cp supabase/.env.example supabase/.env.local
#
# Then run:
#   supabase functions serve generate-devotion --env-file supabase/.env.local

# Required by generate-devotion. Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# These two are auto-injected when you run `supabase functions serve`, so you
# only need to set them when invoking the function outside the CLI.
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... # printed by `supabase status`
